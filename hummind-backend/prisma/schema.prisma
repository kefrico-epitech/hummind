// ========================
// Prisma Client
// ========================
generator client {
  provider = "prisma-client-js"
}

// ========================
// Datasource (PostgreSQL)
// ========================
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// Enums globaux
// ========================
// Rôle au niveau plateforme (= qui es-tu vis-à-vis de Hummind ?)
// - ROOT   : équipe Hummind, accès console /admin
// - MEMBER : utilisateur de la plateforme (institutions, apprenants), par défaut
enum PlatformRole {
  ROOT
  MEMBER
}

enum UserStatus {
  INVITED  // créé par admin, attend la première connexion (mdp temp non changé)
  ACTIVE   // compte normal opérationnel
  DISABLED // désactivation volontaire (ou RGPD)
  BANNED   // bannissement (temporaire via bannedUntil, ou permanent si null)
}

enum EntityStatus {
  ACTIVE // par défaut, peut se connecter
  ARCHIVED // désactivation volontaire (ou RGPD)
  BANNED // bannissement (temporaire via bannedUntil, ou permanent si null)
}

enum EntityType {
  ORGANISATION
  DEPARTEMENT
  SALLE
  INDEPENDANT
}

// Rôles contextuels dans une entité
enum EntityRole {
  OWNER
  ADMIN
  INSTRUCTOR
  LEARNER
  VIEWER
}

// Palette tarifaire (Préparation business — non exploitée v1 mais champ prêt).
enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
  CUSTOM // override manuel par ROOT
}

// ========================
// Modèles Utilisateurs & Tokens
// ========================
model User {
  id              String       @id @default(uuid())
  firstname       String
  lastname        String
  email           String       @unique
  passwordHash    String?
  googleId        String?      @unique
  platformRole    PlatformRole @default(MEMBER)
  emailVerifiedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  picture         String?

  // Authentification — flag qui force le passage par /first-login après signin
  // tant qu'il est vrai (cas des comptes créés par admin avec mdp temporaire).
  mustChangePassword Boolean @default(false)

  // 2FA (TOTP). Obligatoire pour ROOT, optionnel pour MEMBER.
  // totpSecret stocké côté DB — l'app ne le réexpose jamais via API.
  totpEnabled Boolean @default(false)
  totpSecret  String?

  // Statut & métadonnées
  status      UserStatus @default(ACTIVE)
  statusNote  String?
  bannedUntil DateTime?
  disabledAt  DateTime?
  // Soft-delete (GDPR). NULL = compte actif. Date = supprimé/anonymisé.
  // Les queries normales doivent filtrer `deletedAt: null`.
  deletedAt   DateTime?

  // Relations
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  verifications       VerificationToken[]
  entityMemberships   EntityMember[]
  sentInvitations     EntityInvitation[]   @relation("UserSentInvitations")

  // ⬇️ Back-relation correctement nommé + relié par le même nom de relation
  entitiesCreated      Entity[]           @relation("EntityCreatedBy")
  coursesCreated       Course[]           @relation("CourseCreatedBy") // ✅ Relation vers les cours créés
  requestedInvitations EntityInvitation[] @relation("UserRequestedInvitations")
  comments             Comment[]
  notifications        Notification[]
  courseProgress        CourseProgress[]
  courseSessions       CourseSession[]
  courseNotes           CourseNote[]

  // AI / Hummind
  aiUsageLogs       AiUsageLog[]
  learnerMemories   LearnerMemory[]
  conceptMastery    ConceptMastery[]
  affectiveStates   AffectiveState[]

  // Onboarding & support
  acceptedContacts       ContactMessage[]        @relation("ContactAcceptedUser")
  publicJoinLinksCreated PublicJoinLink[]
  emailVerifications     EmailVerificationCode[]
  auditLogActions        AdminAuditLog[]         @relation("AdminAuditActor")

  @@index([email])
  @@index([status])
  @@index([bannedUntil])
  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  userAgent String?
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hash])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ========================
// Entités, Membres, Cours, Invitations
// ========================

// Entité hiérarchique (école, département, ONG, etc.)
model Entity {
  id          String       @id @default(uuid())
  name        String
  description String?
  picture     String? // image de l'entité (nullable)
  type        EntityType   @default(ORGANISATION) // 'organisation', 'département', 'salle','independant'
  status      EntityStatus @default(ACTIVE)

  // Plan & quotas (préparation business, non exploités v1)
  subscriptionTier     SubscriptionTier @default(FREE)
  maxLearners          Int?
  maxCourses           Int?
  maxAiCreditsPerMonth Int?

  // ⬇️ Donne un nom de relation partagé avec le back-relation
  createdById String
  createdBy   User   @relation("EntityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  // Hiérarchie (parent -> enfants)
  parentId String?
  parent   Entity?  @relation("EntityToChildren", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children Entity[] @relation("EntityToChildren")

  // Membres & cours
  members       EntityMember[]
  courses       Course[]
  categories    Category[]         @relation("CategoryOwner")
  invitations   EntityInvitation[]
  notifications Notification[]

  // Lien public d'inscription (pour les salles)
  publicJoinLinks PublicJoinLink[]

  // Relation Many-to-Many vers les catégories (via table de liaison)
  categoryLinks EntityCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Soft-delete (GDPR). NULL = active. Date = supprimée.
  deletedAt DateTime?

  @@unique([parentId, name])
  @@index([parentId])
  @@index([name])
  @@index([createdById])
  @@index([deletedAt])
}

// Lien N-N User <-> Entity avec rôle local
model EntityMember {
  id       String             @id @default(uuid())
  entityId String
  userId   String
  role     EntityRole         @default(LEARNER)
  status   EntityMemberStatus @default(ACTIVE)

  // Tracking du ban
  bannedAt  DateTime?
  bannedBy  String?
  banReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Un user ne peut être membre qu’une seule fois d’une même entité
  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@index([role])
  @@index([status])
}

enum EntityMemberStatus {
  ACTIVE
  BANNED
}

// Cours rattaché à une entité
model Course {
  id          String  @id @default(uuid())
  entityId    String
  title       String
  description String?
  content     Json? // ✅ contenu du cours (structure riche)
  picture     String? // ✅ image du cours

  // Nouveaux champs demandés
  mode       CourseMode       @default(STEP_BY_STEP)
  objectives String[]         @default([])
  visibility CourseVisibility @default(UNLIMITED)
  startDate  DateTime?
  endDate    DateTime?
  domain     String?
  level      String?
  link       String?
  status     CourseStatus     @default(DRAFT)

  // Auteur du cours
  createdById String // ✅ ID de l'auteur (User)
  createdBy   User   @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity   Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  comments Comment[]
  progress CourseProgress[]
  sessions CourseSession[]
  notes    CourseNote[]

  // Hummind AI back-relations
  learnerMemories LearnerMemory[]
  conceptMastery  ConceptMastery[]

  // Relation Many-to-Many avec les catégories (explicite)
  categoryLinks CourseCategory[]
  categories    Category[]

  @@index([entityId])
  @@index([createdById])
  @@index([title])
  @@index([status])
}

enum CourseMode {
  STEP_BY_STEP
  HYBRID
  AI_ONLY
}

enum CourseVisibility {
  UNLIMITED
  LIMITED
  PUBLIC
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Catégorie hiérarchique rattachée à une entité
model Category {
  id       String  @id @default(uuid())
  name     String
  parentId String?
  entityId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity   Entity     @relation("CategoryOwner", fields: [entityId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryToChildren", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children Category[] @relation("CategoryToChildren")

  // ✅ Relation Many-to-Many pour le groupement
  // ✅ Relation One-to-Many vers la table de liaison
  entityLinks EntityCategory[]

  // Relation Many-to-Many avec les cours (explicite)
  courseLinks CourseCategory[]
  course      Course?          @relation(fields: [courseId], references: [id])
  courseId    String?

  @@unique([entityId, parentId, name])
  @@index([entityId])
  @@index([parentId])
  @@index([name])
}

// Table de liaison explicite entre Course et Category (pour Supabase Replica Identity)
model CourseCategory {
  id         String @id @default(uuid())
  courseId   String
  categoryId String

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([courseId, categoryId])
  @@index([courseId])
  @@index([categoryId])
}

// Commentaire d'un utilisateur sur un cours
model Comment {
  id       String @id @default(uuid())
  userId   String
  courseId String
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([createdAt])
}

// Invitation à rejoindre une entité
model EntityInvitation {
  id          String     @id @default(uuid())
  entityId    String
  email       String
  role        EntityRole @default(LEARNER)
  token       String     @unique
  inviterId   String? // SetNull si l’inviteur est supprimé
  requesterId String? // User qui a fait la demande via lien public
  createdAt   DateTime   @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?

  entity    Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  inviter   User?  @relation("UserSentInvitations", fields: [inviterId], references: [id], onDelete: SetNull)
  requester User?  @relation("UserRequestedInvitations", fields: [requesterId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([email])
  @@index([requesterId])
  @@index([expiresAt])
}

// Notification destinÃ©e Ã  un utilisateur (liÃ©e ou non Ã  une entitÃ©)
model Notification {
  id       String    @id @default(uuid())
  userId   String
  entityId String?
  type     String // ex: "COURSE_PUBLISHED", "INVITE_ACCEPTED"
  title    String
  message  String?
  data     Json? // payload libre (ids, metadata)
  readAt   DateTime?

  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

// ========================
// Progression apprenant
// ========================
model CourseProgress {
  id     String @id @default(uuid())
  userId String
  courseId String

  // Blocks completes (IDs des blocks content/quiz/exercise termines)
  completedBlockIds String[] @default([])

  // Dernier step (ID du step dans le live view) pour reprendre ou on en etait
  lastStepId String?

  // Pourcentage precalcule (0-100)
  progressPercent Int @default(0)

  // Score quiz : nombre de bonnes reponses / nombre total
  quizCorrect Int @default(0)
  quizTotal   Int @default(0)

  // Exercices completes
  exercisesCompleted Int @default(0)
  exercisesTotal     Int @default(0)

  startedAt      DateTime  @default(now())
  lastAccessedAt DateTime  @default(now())
  completedAt    DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([progressPercent])
}

// Session de cours par module (persistance des conversations live)
model CourseSession {
  id       String @id @default(uuid())
  userId   String
  courseId  String
  moduleId String

  // Fil de messages complet (tuteur + apprenant)
  messages Json @default("[]")

  // Reponses aux quiz { blockId: { choiceIndex, correct, attempts } }
  quizAnswers Json @default("{}")

  // Brouillons exercices { blockId: text }
  exerciseDrafts Json @default("{}")

  // Evaluations exercices { blockId: "none"|"partial"|"strong" }
  exerciseEvaluations Json @default("{}")

  // Steps completes dans ce module
  completedStepIds String[] @default([])

  // Dernier step actif dans ce module
  lastStepId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, moduleId])
  @@index([userId, courseId])
}

// Notes personnelles de l'apprenant
model CourseNote {
  id       String  @id @default(uuid())
  userId   String
  courseId  String
  moduleId String?
  stepId   String?
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
}

// Table de liaison explicite pour Category <-> Entity
// (Nécessaire pour avoir une PK et supporter le "Replica Identity" de Postgres en suppression)
model EntityCategory {
  id         String @id @default(uuid())
  entityId   String
  categoryId String

  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([entityId, categoryId])
  @@index([entityId])
  @@index([categoryId])
}

// ========================
// Contact / Support — leads des pages publiques
// ========================

enum ContactKind {
  DEMO
  SUPPORT
  GENERAL
}

enum ContactStatus {
  NEW       // demande reçue, jamais traitée
  CONTACTED // ROOT en discussion avec le lead (note interne, pas d'email auto)
  ACCEPTED  // ROOT a accepté, compte créé, identifiants envoyés
  REJECTED  // ROOT a refusé, email de refus envoyé
  ARCHIVED  // gardé pour analytics, hors pipeline actif
}

enum OrganizationType {
  SCHOOL_PRIMARY      // école primaire
  SCHOOL_SECONDARY    // collège / lycée
  UNIVERSITY          // enseignement supérieur
  VOCATIONAL_CENTER   // centre de formation professionnelle
  TRAINING_ORG        // organisme de formation
  CORPORATE           // entreprise (formation interne)
  INDEPENDENT         // enseignant ou formateur indépendant
  OTHER
}

enum LearnerVolume {
  UNDER_50
  BETWEEN_50_200
  BETWEEN_200_1000
  OVER_1000
}

enum ProjectHorizon {
  IMMEDIATE
  WITHIN_1_MONTH
  WITHIN_3_MONTHS
  EXPLORING
}

// Message envoyé depuis les pages publiques (Demo, widget chat).
// Pas de lien obligatoire à un User : l'expéditeur peut ne pas avoir de compte.
model ContactMessage {
  id        String        @id @default(uuid())
  kind      ContactKind   @default(GENERAL)
  status    ContactStatus @default(NEW)

  // Contact
  name      String?
  email     String
  phone     String?
  role      String?

  // Organisation
  organizationName String?
  organizationType OrganizationType?
  learnerVolume    LearnerVolume?
  website          String?
  country          String?
  city             String?

  // Projet
  message String @db.Text
  horizon ProjectHorizon?

  // Méta
  source    String?  // url ou label du formulaire d'origine
  userId    String?  // si l'expéditeur est authentifié, on le relie
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Si ce lead a été accepté par un ROOT, on garde la trace du User créé.
  acceptedUserId String?
  acceptedUser   User?   @relation("ContactAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([kind, status])
  @@index([email])
}

// ========================
// Hummind AI — Mémoire, maîtrise, affect, observabilité
// ========================

// Log d'usage IA. Une ligne par appel OpenAI orchestré par l'AI module.
model AiUsageLog {
  id            String   @id @default(uuid())
  userId        String
  route         String   // "live-session", "live-tutor", "course-generate-progressive", ...
  model         String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  costUsdMicros Int      @default(0) // coût en micro-USD pour éviter les Float
  status        String   // "ok" | "error" | "rate_limited" | "timeout"
  durationMs    Int      @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([route, createdAt(sort: Desc)])
  @@index([status])
}

// Mémoire long-terme par apprenant × cours. Le summary est un texte borné
// (~2000 chars) qui condense ce que l'apprenant a appris. weakSpots/strongSpots
// sont matérialisés ici pour éviter une jointure sur ConceptMastery à chaque turn.
model LearnerMemory {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  summary     String   @db.Text @default("")
  weakSpots   Json     @default("[]") // [{ conceptKey, label, mastery, lastSeenAt }]
  strongSpots Json     @default("[]")
  preferences Json     @default("{}") // { preferredExamples: "concret"|"abstrait", learningPace: "lent"|"normal"|"rapide", ... }
  turnsTotal  Int      @default(0)
  tokensTotal Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

// Maîtrise au niveau concept (granularité fine). mastery est une EMA bayésienne 0..1.
model ConceptMastery {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  conceptKey String   // ex: "module:abc:topic:derivees_regle_chaine"
  label      String   // libellé humain
  mastery    Float    @default(0.0) // 0..1
  attempts   Int      @default(0)
  successes  Int      @default(0)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, conceptKey])
  @@index([userId, courseId, mastery]) // pour "top N weak/strong"
}

// État affectif inféré à partir des interactions. Une ligne par turn (append-only).
model AffectiveState {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  sessionId  String?
  mood       Mood
  confidence Float    @default(0.5) // 0..1
  streakWin  Int      @default(0)
  streakLoss Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, courseId, createdAt(sort: Desc)])
}

enum Mood {
  ENGAGED
  TRIUMPHANT
  FRUSTRATED
  CONFUSED
  BORED
  ANXIOUS
}

// ========================
// Onboarding & Support (Flow v2.0)
// ========================

// Lien public attaché à une SALLE pour permettre aux apprenants de s'inscrire
// directement (cf. /join/[code]). Distinct de EntityInvitation qui sert à
// inviter un User déjà existant.
model PublicJoinLink {
  id          String   @id @default(uuid())
  code        String   @unique // 6-8 caractères, base32 sans ambigüités (Crockford-like)
  entityId    String   // doit pointer sur une Entity de type SALLE
  enabled     Boolean  @default(true)
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity    Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([entityId, enabled])
}

// Code OTP (6 chiffres) envoyé par email pour vérifier l'adresse d'un nouvel
// apprenant inscrit via /join/[code]. Expiration 2h, 5 tentatives max.
model EmailVerificationCode {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String    // hash argon2 du code à 6 chiffres
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

// Audit trail des actions sensibles côté ROOT et admins d'organisation.
// Indispensable pour la conformité et le debug post-incident.
model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String?  // null pour actions système (jobs, cron, etc.)
  action     String   // ex: "CONTACT_ACCEPTED", "USER_BANNED", "PUBLIC_JOIN_LINK_TOGGLED"
  targetType String?  // "user" | "contact" | "entity" | "publicJoinLink"
  targetId   String?
  payload    Json?    // contexte additionnel (ancien/nouveau status, raison, etc.)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}
