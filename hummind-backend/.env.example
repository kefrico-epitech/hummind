# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Prisma) ---
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local Postgres dev via docker-compose.dev.yml (port 5433 pour éviter un Postgres natif sur 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hummindos_db?schema=public

# --- JWT / Auth ---
JWT_AT_SECRET=change_me_access_secret
JWT_RT_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=change_number_day
GOOGLE_CLIENT_ID=change_me_google_client_id

# --- Cookies ---
COOKIE_SECRET=change_me_cookie_secret

# --- Logger ---
# Niveau de log pour Pino (trace, debug, info, warn, error, fatal, silent)
LOG_LEVEL=debug

# --- Autres (optionnels) ---
# Swagger docs active seulement si NODE_ENV != production
# Pour limiter les IP autorisées à Swagger, crée une variable :
# SWAGGER_ALLOWLIST=127.0.0.1,::1


# SMTP Gmail via App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true            # 465 => true ; 587 => false
SMTP_USER=ton.email@gmail.com
SMTP_PASS=ton_app_password  # généré dans Google Account > Security > App passwords

# Métadonnées emails
MAIL_FROM="HummindOS <no-reply@hummindos.local>"
FRONTEND_URL=http://localhost:4200

# --- Hummind AI (OpenAI) ---
# Clé API OpenAI (obligatoire pour le module ai/)
OPENAI_API_KEY=sk-...

# Modèles par cascade (le premier dispo est utilisé). Tous optionnels :
# si rien n'est défini, le backend bascule sur gpt-4o-mini puis gpt-4o.
# OPENAI_LIVE_MODEL=gpt-4o-mini
# OPENAI_COURSE_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# --- Redis (BullMQ pour les jobs asynchrones : emails, summarizer) ---
# Local dev via docker-compose.dev.yml (port 6380 pour éviter un Redis natif sur 6379)
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=  # uniquement si auth activée

# --- Seed admin (test only) ---
# Override pour ne pas committer "admin123" en prod
# ADMIN_SEED_EMAIL=admin@hummind.com
# ADMIN_SEED_PASSWORD=admin123
