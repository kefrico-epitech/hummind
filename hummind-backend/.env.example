# ── Serveur ───────────────────────────────────────────────
NODE_ENV=development
PORT=5500
CORS_ORIGIN=http://localhost:5000
APP_URL=http://localhost:5000
LOG_LEVEL=info

# ── Base de données ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hummind?schema=public

# ── JWT / Auth ────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Mail (SMTP — Mailhog en dev) ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Hummind <no-reply@hummind.com>

# ── IA ────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
TUTOR_MODEL=gpt-4o-mini
