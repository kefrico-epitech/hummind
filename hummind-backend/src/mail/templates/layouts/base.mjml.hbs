<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Inter, Arial, sans-serif" />
      <mj-text color="#0f172a" font-size="14px" line-height="1.6" />
      <mj-button background-color="#0ea5e9" color="#ffffff" font-weight="700" border-radius="10px" />
      <mj-class name="card" padding="24px" border-radius="16px" background-color="#ffffff" />
    </mj-attributes>
    <mj-preview>{{preview}}</mj-preview>
  </mj-head>
  <mj-body background-color="#e2e8f0">
    {{> header}}
    <mj-section padding="24px 0">
      <mj-column width="600px">
        <mj-wrapper css-class="card">
          {{{content}}}
        </mj-wrapper>
      </mj-column>
    </mj-section>
    {{> footer}}
  </mj-body>
</mjml>
